# Normalize all repository text files to Unix LF.
* text=auto

*.c          text eol=lf
*.h          text eol=lf
*.s          text eol=lf
*.ld         text eol=lf
*.ioc        text eol=lf
*.xml        text eol=lf
*.prefs      text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
*.cmake      text eol=lf
CMakeLists.txt text eol=lf

# STM32CubeIDE metadata.
*.project    text eol=lf
*.cproject   text eol=lf
*.mxproject  text eol=lf

# Binary firmware artifacts.
*.elf        binary
*.bin        binary
*.o          binary
